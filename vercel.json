{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": true,
  "buildCommand": "python generator.py",
  "outputDirectory": "output",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.classnova.kr"
        }
      ],
      "destination": "https://classnova.kr/$1",
      "permanent": true
    }
  ]
}
